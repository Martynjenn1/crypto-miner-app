<!DOCTYPE html>
<html>
<head>
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Mobile Crypto Miner</title>
<link rel="manifest" href="manifest.json">

<style>

body{
background:#0f172a;
font-family:Arial;
color:white;
text-align:center;
padding:20px;
}

.container{
max-width:420px;
margin:auto;
background:#1e293b;
padding:20px;
border-radius:15px;
}

.stat{
font-size:20px;
margin:15px 0;
}

button{
width:100%;
padding:15px;
margin-top:10px;
font-size:18px;
border:none;
border-radius:10px;
background:#22c55e;
color:white;
}

.price{
color:#38bdf8;
font-size:18px;
}

</style>
</head>

<body>

<div class="container">

<h2>Crypto Mining App</h2>

<div class="stat">
Hash Rate: <span id="hash">0</span> H/s
</div>

<div class="stat">
Coins Mined: <span id="coins">0</span>
</div>

<div class="stat price">
BTC Price: $<span id="btc">loading...</span>
</div>

<button onclick="startMining()">Start Mining</button>
<button onclick="stopMining()">Stop Mining</button>

</div>

<script>

let mining=false
let coins=0

function startMining(){
mining=true
mine()
}

function stopMining(){
mining=false
}

function mine(){

if(!mining) return

let hash=Math.floor(Math.random()*200)+100

document.getElementById("hash").innerText=hash

coins+=Math.random()*0.00005

document.getElementById("coins").innerText=coins.toFixed(6)

setTimeout(mine,1000)

}

async function getPrice(){

let res = await fetch("https://api.coingecko.com/api/v3/simple/price?ids=bitcoin&vs_currencies=usd")

let data = await res.json()

document.getElementById("btc").innerText=data.bitcoin.usd

}

getPrice()

setInterval(getPrice,30000)

</script>

</body>
</html>